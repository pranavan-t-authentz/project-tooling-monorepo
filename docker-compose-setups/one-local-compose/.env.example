# Shared environment for one-local.docker-compose.yml
# Copy to .env in this directory: cp .env.example .env

# AWS (mounted from ~/.aws/credentials into containers)
AWS_PROFILE=741448925364_AdministratorAccess
AWS_DEFAULT_REGION=eu-west-2

# Postgres host port — use 5433 if local Postgres already uses 5432
POSTGRES_PORT=5433

# Frontend → Flask API (browser uses host ports, not Docker service names)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional: override frontend OAuth client credentials via authentz-frontend-next/.env.local
# Get values from Secrets Manager: authentz/allsecrets
